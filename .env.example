# Required
ANTHROPIC_API_KEY=sk-ant-…
GEMINI_API_KEY=AIza…

# Required for Stage 5 (PPTX)
SLIDE_PREVIEW_URL=http://localhost:5173

# Optional tuning
GEMINI_CONCURRENCY=5       # Max simultaneous Imagen requests (default: 5)
SCREENSHOT_CONCURRENCY=5   # Max simultaneous Puppeteer pages (default: 5)
FONT_SETTLE_MS=600         # ms after networkidle0 before screenshot (default: 600)
SECTIONS_PER_CHUNK=8       # Max sections per Opus call for large modules (default: 8)
